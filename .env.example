# ---- Backend (apps/api reads this via pydantic-settings; copy to .env) ----
# Copy this file to `.env` and fill in real values. `.env` is gitignored; this file is not.
# Never put real secrets in this example file.

# Contact email sent in User-Agent to SEC/Wikipedia (SEC requires it)
CONTACT_EMAIL=you@example.com

# LLM provider chain, tried in order. Leave keys empty to run in no-LLM degraded mode.
LLM_CHAIN=groq,cerebras,openrouter,ollama

GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

CEREBRAS_API_KEY=
CEREBRAS_MODEL=llama-3.3-70b

OPENROUTER_API_KEY=
OPENROUTER_MODEL=meta-llama/llama-3.3-70b-instruct:free

# Local Ollama (no key needed); leave OLLAMA_MODEL empty to skip
OLLAMA_BASE_URL=http://localhost:11434/v1
OLLAMA_MODEL=

# Optional: Firecrawl for scraping JS-heavy pages + web search (free tier).
# Unlocks the "profile" and "funding" agents and lets Lynx research businesses
# with no Wikipedia/SEC footprint.
FIRECRAWL_API_KEY=
