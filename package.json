{
  "name": "business-research",
  "private": true,
  "scripts": {
    "dev": "concurrently -n api,web -c blue,green \"pnpm dev:api\" \"pnpm dev:web\"",
    "dev:api": "cd apps/api && uv run uvicorn app.main:app --reload --port 8000",
    "dev:web": "pnpm --filter web dev",
    "gen:api": "openapi-typescript http://localhost:8000/openapi.json -o apps/web/src/lib/api/schema.d.ts"
  },
  "devDependencies": {
    "concurrently": "^9.2.4",
    "openapi-typescript": "^7.13.0"
  },
  "packageManager": "pnpm@10.30.3"
}
